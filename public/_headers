# Cloudflare Pages — global security + caching headers

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Cache hashed assets forever (Vite fingerprints all asset filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache the HTML entry point — always fetch fresh so routing stays correct
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Cache robots.txt and sitemap briefly
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=3600
